\@writefile{lof}{\contentsline {figure}{\numberline {1.5}{\ignorespaces One-at-a-time sensitivity of the \SI {75}{\metre } time to a $\pm 10\,\%$ perturbation of each vehicle parameter. Centre-of-gravity longitudinal position and tyre peak grip dominate; drivetrain efficiency, gear ratio, mass and wheel radius form a second band; aerodynamic drag and rolling resistance are negligible over \SI {75}{\metre }.}}{13}{figure.caption.11}\protected@file@percent }
\newlabel{fig:tornado}{{1.5}{13}{One-at-a-time sensitivity of the \SI {75}{\metre } time to a $\pm 10\,\%$ perturbation of each vehicle parameter. Centre-of-gravity longitudinal position and tyre peak grip dominate; drivetrain efficiency, gear ratio, mass and wheel radius form a second band; aerodynamic drag and rolling resistance are negligible over \SI {75}{\metre }}{figure.caption.11}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1.6}{\ignorespaces Sensitivity ranking and design-target ranges provided to neighbouring chapters. The ``worst-case $\pm $10\% delta'' column is the larger absolute time change from either perturbation direction. Ranges are chosen to keep the predicted \SI {75}{\metre } time within \SI {1}{\percent } of the baseline.}}{13}{table.caption.12}\protected@file@percent }
\newlabel{tab:sensitivity_ranking}{{1.6}{13}{Sensitivity ranking and design-target ranges provided to neighbouring chapters. The ``worst-case $\pm $10\% delta'' column is the larger absolute time change from either perturbation direction. Ranges are chosen to keep the predicted \SI {75}{\metre } time within \SI {1}{\percent } of the baseline}{table.caption.12}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {1.4.2}Monte Carlo robustness}{14}{subsection.1.4.2}\protected@file@percent }
\newlabel{sec:monte_carlo}{{1.4.2}{14}{Monte Carlo robustness}{subsection.1.4.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1.6}{\ignorespaces Distribution of the predicted \SI {75}{\metre } time over \num {500} Monte Carlo samples. The mean of \SI {4.03}{\second } sits slightly above the baseline \SI {3.78}{\second } because the response is asymmetric: unfavourable perturbations (lower grip, heavier, higher CG) produce a larger time penalty than favourable perturbations give a reduction. All \num {500} samples satisfied FS-EV~2.2 and FS-D~5.3.1 and remained wheelie-free.}}{14}{figure.caption.13}\protected@file@percent }
\newlabel{fig:mc_histogram}{{1.6}{14}{Distribution of the predicted \SI {75}{\metre } time over \num {500} Monte Carlo samples. The mean of \SI {4.03}{\second } sits slightly above the baseline \SI {3.78}{\second } because the response is asymmetric: unfavourable perturbations (lower grip, heavier, higher CG) produce a larger time penalty than favourable perturbations give a reduction. All \num {500} samples satisfied FS-EV~2.2 and FS-D~5.3.1 and remained wheelie-free}{figure.caption.13}{}}
