\@writefile{lot}{\contentsline {table}{\numberline {1.2}{\ignorespaces Decomposition of the \SI {1.08}{\second } gap between the simulated \SI {75}{\metre } time and the analytical lower bound of Eq.~\ref {eq:analytical_bound}. Each row converts an energy-loss channel, integrated over the run, into an equivalent time penalty against the \SI {80}{\kilo \watt } reference. The traction-limited deficit integrates the shortfall $P_\text  {max} - P_\text  {elec}(t)$ over the launch phase; the residual absorbs the overlap between channels and the \SI {80}{\milli \second } launch-torque ramp.}}{10}{table.caption.6}\protected@file@percent }
\newlabel{tab:time_decomp}{{1.2}{10}{Decomposition of the \SI {1.08}{\second } gap between the simulated \SI {75}{\metre } time and the analytical lower bound of Eq.~\ref {eq:analytical_bound}. Each row converts an energy-loss channel, integrated over the run, into an equivalent time penalty against the \SI {80}{\kilo \watt } reference. The traction-limited deficit integrates the shortfall $P_\text {max} - P_\text {elec}(t)$ over the launch phase; the residual absorbs the overlap between channels and the \SI {80}{\milli \second } launch-torque ramp}{table.caption.6}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1.3}{\ignorespaces Energy budget integrated over the \SI {75}{\metre } run. The electrical input energy splits between kinetic energy at the finish, drivetrain losses, and aerodynamic dissipation. Rolling resistance is negligibly small over the event length.}}{10}{table.caption.7}\protected@file@percent }
\newlabel{tab:energy_budget}{{1.3}{10}{Energy budget integrated over the \SI {75}{\metre } run. The electrical input energy splits between kinetic energy at the finish, drivetrain losses, and aerodynamic dissipation. Rolling resistance is negligibly small over the event length}{table.caption.7}{}}
