\abx@aux@cite{0}{milliken1995}
\abx@aux@segm{0}{0}{milliken1995}
\@writefile{lof}{\contentsline {figure}{\numberline {1.7}{\ignorespaces Convergence of the Nelder--Mead optimiser over \num {271} objective evaluations. Upper panel: every evaluated \SI {75}{\metre } time (grey dots) together with the best-so-far feasible time (blue). Lower panel: peak electrical power per evaluation against the FS-EV~2.2 cap; wheelie-violating evaluations are marked as red crosses and rejected by the penalty in the objective.}}{16}{figure.caption.15}\protected@file@percent }
\newlabel{fig:optim_convergence}{{1.7}{16}{Convergence of the Nelder--Mead optimiser over \num {271} objective evaluations. Upper panel: every evaluated \SI {75}{\metre } time (grey dots) together with the best-so-far feasible time (blue). Lower panel: peak electrical power per evaluation against the FS-EV~2.2 cap; wheelie-violating evaluations are marked as red crosses and rejected by the penalty in the objective}{figure.caption.15}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1.8}{\ignorespaces Optimisation result. The converged design moves the CG forward relative to the baseline, tightens the gear ratio and increases anti-squat, and chooses a modestly smaller wheel radius. The launch torque cap is reduced to prevent the tyre from spinning through the Pacejka peak.}}{16}{table.caption.16}\protected@file@percent }
\newlabel{tab:optim_result}{{1.8}{16}{Optimisation result. The converged design moves the CG forward relative to the baseline, tightens the gear ratio and increases anti-squat, and chooses a modestly smaller wheel radius. The launch torque cap is reduced to prevent the tyre from spinning through the Pacejka peak}{table.caption.16}{}}
